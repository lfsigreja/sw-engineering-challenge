{
  "info": {
    "name": "Bloqit API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "bloqId",
      "value": "c3ee858c-f3d8-45a3-803d-e080649bbb6f",
      "type": "string"
    },
    {
      "key": "lockerId",
      "value": "1b8d1e89-2514-4d91-b813-044bf0ce8d20",
      "type": "string"
    },
    {
      "key": "rentId",
      "value": "50be06a8-1dec-4b18-a23c-e98588207752",
      "type": "string"
    },
    {
      "key": "correlationId",
      "value": "my-trace-id-001",
      "type": "string",
      "description": "Passed as x-correlation-id request header and echoed back in the response. Leave blank to let the server generate a UUID."
    }
  ],
  "item": [
    {
      "name": "Observability",
      "item": [
        {
          "name": "Liveness — GET /health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-correlation-id",
                "value": "{{correlationId}}",
                "description": "Optional. Echoed back in the response header."
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Liveness probe. Returns { status, uptime }. Should always be fast; used by Kubernetes/Docker to detect a crashed process."
          }
        },
        {
          "name": "Readiness — GET /ready",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-correlation-id",
                "value": "{{correlationId}}",
                "description": "Optional. Echoed back in the response header."
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/ready",
              "host": ["{{baseUrl}}"],
              "path": ["ready"]
            },
            "description": "Readiness probe. Verifies the data directory is writable and returns the deployed version. Returns 503 when the service is not ready to accept traffic."
          }
        },
        {
          "name": "Prometheus metrics — GET /metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["metrics"]
            },
            "description": "Exposes Prometheus-format metrics: default Node.js process metrics + http_request_duration_seconds histogram labelled by method, route, and status_code."
          }
        }
      ]
    },
    {
      "name": "Bloqs",
      "item": [
        {
          "name": "List bloqs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/bloqs",
              "host": ["{{baseUrl}}"],
              "path": ["bloqs"]
            }
          }
        },
        {
          "name": "Find bloq by id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/bloqs/{{bloqId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bloqs", "{{bloqId}}"]
            }
          }
        },
        {
          "name": "Create bloq",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('bloqId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Bloq\",\n  \"address\": \"456 New Street, City, Country\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bloqs",
              "host": ["{{baseUrl}}"],
              "path": ["bloqs"]
            }
          }
        },
        {
          "name": "Update bloq",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Bloq Title\",\n  \"address\": \"789 Updated Ave, City, Country\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bloqs/{{bloqId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bloqs", "{{bloqId}}"]
            }
          }
        },
        {
          "name": "Delete bloq",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/bloqs/{{bloqId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bloqs", "{{bloqId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Lockers",
      "item": [
        {
          "name": "List lockers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/lockers",
              "host": ["{{baseUrl}}"],
              "path": ["lockers"]
            }
          }
        },
        {
          "name": "Find locker by id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/lockers/{{lockerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["lockers", "{{lockerId}}"]
            }
          }
        },
        {
          "name": "Create locker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('lockerId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloqId\": \"{{bloqId}}\",\n  \"status\": \"OPEN\",\n  \"isOccupied\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/lockers",
              "host": ["{{baseUrl}}"],
              "path": ["lockers"]
            }
          }
        },
        {
          "name": "Update locker",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLOSED\",\n  \"isOccupied\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/lockers/{{lockerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["lockers", "{{lockerId}}"]
            }
          }
        },
        {
          "name": "Delete locker",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/lockers/{{lockerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["lockers", "{{lockerId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Rents",
      "item": [
        {
          "name": "List rents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/rents",
              "host": ["{{baseUrl}}"],
              "path": ["rents"]
            }
          }
        },
        {
          "name": "Get rent",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/rents/{{rentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rents", "{{rentId}}"]
            }
          }
        },
        {
          "name": "Create rent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('rentId', res.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weight\": 5,\n  \"size\": \"M\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rents",
              "host": ["{{baseUrl}}"],
              "path": ["rents"]
            }
          }
        },
        {
          "name": "Transition rent to WAITING_DROPOFF",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"WAITING_DROPOFF\",\n  \"lockerId\": \"{{lockerId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rents/{{rentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rents", "{{rentId}}"]
            }
          }
        },
        {
          "name": "Transition rent to WAITING_PICKUP",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"WAITING_PICKUP\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rents/{{rentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rents", "{{rentId}}"]
            }
          }
        },
        {
          "name": "Transition rent to DELIVERED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DELIVERED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rents/{{rentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rents", "{{rentId}}"]
            }
          }
        },
        {
          "name": "Delete rent",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/rents/{{rentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["rents", "{{rentId}}"]
            }
          }
        }
      ]
    }
  ]
}
